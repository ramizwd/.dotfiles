{
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "tray": {
        "spacing": 10,
        "icon-size": 18,
    },

    "clock": {
        "tooltip-format": "<tt><big>{calendar}</big></tt>",
        "format": "{:%d/%m - %H:%M}",
    },

    "cpu": {
        "interval": 1,
        "format": "  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
        "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"],
        "on-click": "kitty --class system-popup -e btop"
    },

    "memory": {
        "interval": 30,
        "format": "  {}%",
        "on-click": "kitty --class system-popup -e btop"
    },

    "hyprland/language": {
        "format": "󰌌  {}",
        "format-en": "US",
        "format-fi": "FI",
        "on-click": "hyprctl switchxkblayout all next"
    },

    "custom/clipboard": {
        "interval": 1,
        "format": "{}",
        "exec": "cliphist list | grep -q . && echo '󰅍'",
        "on-click": "rofi-cliphist-img.sh",
        "on-click-right": "clip-clear.sh",
        "tooltip": false
    },

    "custom/razer": {
        "exec": "razer-bat-json.py",
        "interval": 60,
        "return-type": "json",
        "format": "{}"
    },

    "network": {
        "format-ethernet": " ",
        "format-disconnected": "Disconnected ",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "  {volume}%",
        "format-icons": {
            "default": ["", "", " "]
        },
        "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"pavucontrol\", { float = true, size = {1300, 800} })'"
    },

    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "powermenu.sh"
    },

    "custom/weather": {
        "interval": 3600,
        "format": "{}",
        "tooltip": true,
        "exec": "weather.sh",
        "return-type": "text",
        "on-click": "wttr-popup.sh",
        "on-click-right": "wttr-popup.sh v2"
    },
}
